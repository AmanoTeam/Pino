From fd283cb835b631e91c23776beca422b2ca605c21 Mon Sep 17 00:00:00 2001
From: Kartatz <105828205+Kartatz@users.noreply.github.com>
Date: Wed, 30 Jul 2025 02:04:58 -0300
Subject: [PATCH] Fix declaration of mblen

---
 libstdc++-v3/include/c_compatibility/stdlib.h | 2 ++
 libstdc++-v3/include/c_global/cstdlib         | 8 +++++++-
 libstdc++-v3/include/c_global/cwctype         | 4 +++-
 3 files changed, 12 insertions(+), 2 deletions(-)

diff --git a/libstdc++-v3/include/c_compatibility/stdlib.h b/libstdc++-v3/include/c_compatibility/stdlib.h
index 283496269..50c057eb8 100644
--- a/libstdc++-v3/include/c_compatibility/stdlib.h
+++ b/libstdc++-v3/include/c_compatibility/stdlib.h
@@ -67,7 +67,9 @@ using std::labs;
 using std::ldiv;
 using std::malloc;
 #ifdef _GLIBCXX_HAVE_MBSTATE_T
+#if !(defined(__ANDROID__) && __ANDROID_API__ < 26)
 using std::mblen;
+#endif
 using std::mbstowcs;
 using std::mbtowc;
 #endif // _GLIBCXX_HAVE_MBSTATE_T
diff --git a/libstdc++-v3/include/c_global/cstdlib b/libstdc++-v3/include/c_global/cstdlib
index ced924793..a4ec013f5 100644
--- a/libstdc++-v3/include/c_global/cstdlib
+++ b/libstdc++-v3/include/c_global/cstdlib
@@ -160,15 +160,19 @@ _GLIBCXX_BEGIN_NAMESPACE_VERSION
   using ::ldiv;
   using ::malloc;
 #ifdef _GLIBCXX_HAVE_MBSTATE_T
+#if !(defined(__ANDROID__) && __ANDROID_API__ < 26)
   using ::mblen;
+#endif
   using ::mbstowcs;
+#if !(defined(__ANDROID__) && __ANDROID_API__ < 21)
   using ::mbtowc;
+#endif
 #endif // _GLIBCXX_HAVE_MBSTATE_T
   using ::qsort;
 #if __cplusplus >= 201103L
 # ifdef _GLIBCXX_HAVE_QUICK_EXIT
   using ::quick_exit;
-# endif
+
 #endif
   using ::rand;
   using ::realloc;
@@ -179,7 +183,9 @@ _GLIBCXX_BEGIN_NAMESPACE_VERSION
   using ::system;
 #ifdef _GLIBCXX_USE_WCHAR_T
   using ::wcstombs;
+#if !(defined(__ANDROID__) && __ANDROID_API__ < 21)
   using ::wctomb;
+#endif
 #endif // _GLIBCXX_USE_WCHAR_T
 
 #ifndef __CORRECT_ISO_CPP_STDLIB_H_PROTO
diff --git a/libstdc++-v3/include/c_global/cwctype b/libstdc++-v3/include/c_global/cwctype
index 07471eb00..15e6e1184 100644
--- a/libstdc++-v3/include/c_global/cwctype
+++ b/libstdc++-v3/include/c_global/cwctype
@@ -100,10 +100,12 @@ namespace std
   using ::iswspace;
   using ::iswupper;
   using ::iswxdigit;
+#if !(defined(__ANDROID__) && __ANDROID_API__ < 26)
   using ::towctrans;
+  using ::wctrans;
+#endif
   using ::towlower;
   using ::towupper;
-  using ::wctrans;
   using ::wctype;
 } // namespace
 
-- 
