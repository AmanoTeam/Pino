diff --git a/gcc/Makefile.in b/gcc/Makefile.in
index 55b4cd7db..da74d4469 100644
--- a/gcc/Makefile.in
+++ b/gcc/Makefile.in
@@ -344,7 +344,7 @@ PWD_COMMAND = $${PWDCMD-pwd}
