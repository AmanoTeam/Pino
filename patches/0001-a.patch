From a4ed36c52e5a0779e9b3a5a325b97feea62c0ca0 Mon Sep 17 00:00:00 2001
From: Kartatz <105828205+Kartatz@users.noreply.github.com>
Date: Tue, 3 Jun 2025 17:46:19 -0300
Subject: [PATCH] a

---
 libstdc++-v3/include/c_compatibility/stdio.h | 4 +++-
 libstdc++-v3/include/c_global/cstdio         | 4 +++-
 libstdc++-v3/src/c++23/std-clib.cc.in        | 4 +++-
 3 files changed, 9 insertions(+), 3 deletions(-)

diff --git a/libstdc++-v3/include/c_compatibility/stdio.h b/libstdc++-v3/include/c_compatibility/stdio.h
index 7241481..0c39a20 100644
--- a/libstdc++-v3/include/c_compatibility/stdio.h
+++ b/libstdc++-v3/include/c_compatibility/stdio.h
@@ -72,9 +72,11 @@ using std::puts;
 using std::ungetc;
 using std::fread;
 using std::fwrite;
+#if defined(__ANDROID__) && (__ANDROID_API__ >= 24 || defined(__aarch64__) || defined(__x86_64__))
 using std::fgetpos;
-using std::fseek;
 using std::fsetpos;
+#endif
+using std::fseek;
 using std::ftell;
 using std::rewind;
 using std::clearerr;
diff --git a/libstdc++-v3/include/c_global/cstdio b/libstdc++-v3/include/c_global/cstdio
index 8d4aa8b..4e85408 100644
--- a/libstdc++-v3/include/c_global/cstdio
+++ b/libstdc++-v3/include/c_global/cstdio
@@ -106,7 +106,6 @@ namespace std
   using ::ferror;
   using ::fflush;
   using ::fgetc;
-  using ::fgetpos;
   using ::fgets;
   using ::fopen;
   using ::fprintf;
@@ -116,7 +115,10 @@ namespace std
   using ::freopen;
   using ::fscanf;
   using ::fseek;
+#if defined(__ANDROID__) && (__ANDROID_API__ >= 24 || defined(__aarch64__) || defined(__x86_64__))
   using ::fsetpos;
+  using ::fgetpos;
+#endif
   using ::ftell;
   using ::fwrite;
   using ::getc;
diff --git a/libstdc++-v3/src/c++23/std-clib.cc.in b/libstdc++-v3/src/c++23/std-clib.cc.in
index 10fc03e..aa7f375 100644
--- a/libstdc++-v3/src/c++23/std-clib.cc.in
+++ b/libstdc++-v3/src/c++23/std-clib.cc.in
@@ -438,7 +438,6 @@ export C_LIB_NAMESPACE
   using std::ferror;
   using std::fflush;
   using std::fgetc;
-  using std::fgetpos;
   using std::fgets;
   using std::FILE;
   using std::fopen;
@@ -450,7 +449,10 @@ export C_LIB_NAMESPACE
   using std::freopen;
   using std::fscanf;
   using std::fseek;
+#if defined(__ANDROID__) && (__ANDROID_API__ >= 24 || defined(__aarch64__) || defined(__x86_64__))
+  using std::fgetpos;
   using std::fsetpos;
+#endif
   using std::ftell;
   using std::fwrite;
   using std::getc;
-- 
2.49.0

